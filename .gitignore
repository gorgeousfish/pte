# ============================================================
# pte-stata .gitignore
# ============================================================

# ----------------------------------------------------------
# Test & development files (not for distribution)
# ----------------------------------------------------------

# Test utilities
ado/_pte_test_*.ado
ado/_epic010_test_helpers.ado
ado/_test_syntax_ado.ado

# Development scripts
mata/_pte_mata_endopoly_patch.do
mata/_pte_treatdep_seed_placeholders.do
mata/_pte_treatdep_source_loader.do

# ----------------------------------------------------------
# Stata artifacts
# ----------------------------------------------------------

# Batch-mode logs
*.log

# Graph files (binary, should be regenerated)
*.gph
*.eps

# Stata editor swap files
~*.stswp

# ----------------------------------------------------------
# Temporary & OS artifacts
# ----------------------------------------------------------

# Temporary files
tmp_*
*.tmp

# Python cache
__pycache__/
*.pyc

# macOS
.DS_Store
._*

# Windows
Thumbs.db
desktop.ini

# Editor / IDE
*.swp
*.swo
*~
.vscode/
.idea/

# Excluded from GitHub release
.github/
docs/
tests/
\$CODEX_HOME/
